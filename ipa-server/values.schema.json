{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": false,
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "properties": {
        "repository": {
          "default": "quay.io/freeipa/freeipa-server",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "centos-9-stream",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "tag"
      ],
      "title": "image",
      "type": "object"
    },
    "ingress": {
      "additionalProperties": false,
      "properties": {
        "className": {
          "default": "openshift-default",
          "title": "className",
          "type": "string"
        },
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        },
        "hostname": {
          "default": "ipa-server.example.test",
          "title": "hostname",
          "type": "string"
        },
        "passthrough": {
          "default": true,
          "title": "passthrough",
          "type": "boolean"
        }
      },
      "required": [
        "enabled",
        "className",
        "hostname",
        "passthrough"
      ],
      "title": "ingress",
      "type": "object"
    },
    "ipaServer": {
      "additionalProperties": false,
      "properties": {
        "adminPassword": {
          "default": "admin2023",
          "title": "adminPassword",
          "type": "string"
        },
        "command": {
          "default": "ipa-server-install",
          "title": "command",
          "type": "string"
        },
        "installOpts": {
          "default": "-U -r EXAMPLE.TEST --setup-dns --no-forwarders --no-ntp",
          "title": "installOpts",
          "type": "string"
        }
      },
      "required": [
        "installOpts",
        "command",
        "adminPassword"
      ],
      "title": "ipaServer",
      "type": "object"
    },
    "openshift": {
      "default": true,
      "title": "openshift",
      "type": "boolean"
    },
    "resources": {
      "additionalProperties": false,
      "properties": {
        "limits": {
          "additionalProperties": false,
          "properties": {
            "memory": {
              "default": "512Mi",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [
            "memory"
          ],
          "title": "limits",
          "type": "object"
        }
      },
      "required": [
        "limits"
      ],
      "title": "resources",
      "type": "object"
    },
    "serviceAccount": {
      "default": "ipa-server",
      "title": "serviceAccount",
      "type": "string"
    },
    "volume": {
      "additionalProperties": false,
      "properties": {
        "size": {
          "default": "5Gi",
          "title": "size",
          "type": "string"
        }
      },
      "required": [
        "size"
      ],
      "title": "volume",
      "type": "object"
    }
  },
  "required": [
    "image",
    "openshift",
    "volume",
    "resources",
    "serviceAccount",
    "ipaServer",
    "ingress",
    "affinity"
  ],
  "type": "object"
}