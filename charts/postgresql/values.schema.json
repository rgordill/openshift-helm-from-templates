{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": false,
      "description": "Pod affinity/anti-affinity rules",
      "required": [],
      "title": "affinity"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "Container image configuration",
      "properties": {
        "repository": {
          "default": "registry.redhat.io/rhel9/postgresql-15",
          "description": "Image registry and repository",
          "required": [],
          "title": "repository"
        },
        "tag": {
          "default": "latest",
          "description": "Image tag",
          "required": [],
          "title": "tag"
        }
      },
      "required": [],
      "title": "image"
    },
    "monitor": {
      "default": "true",
      "description": "Enable ServiceMonitor for Prometheus",
      "required": [],
      "title": "monitor"
    },
    "postgresql": {
      "additionalProperties": false,
      "description": "PostgreSQL server configuration",
      "properties": {
        "adminPassword": {
          "default": "adminpassword",
          "description": "Admin password (overridden at deploy)",
          "required": [],
          "title": "adminPassword"
        },
        "database": {
          "default": "sampledb",
          "description": "Database name to create",
          "required": [],
          "title": "database"
        },
        "password": {
          "default": "password",
          "description": "Custom password (overridden at deploy)",
          "required": [],
          "title": "password"
        },
        "user": {
          "default": "user",
          "description": "Custom user credentials (overridden at deploy)",
          "required": [],
          "title": "user"
        }
      },
      "required": [],
      "title": "postgresql"
    },
    "resources": {
      "additionalProperties": false,
      "description": "Resource limits and requests",
      "properties": {
        "limits": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "0.5",
              "description": "CPU limit",
              "required": [],
              "title": "cpu"
            },
            "memory": {
              "default": "512Mi",
              "description": "Memory limit",
              "required": [],
              "title": "memory"
            }
          },
          "required": [],
          "title": "limits",
          "type": "object"
        },
        "requests": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "0.1",
              "description": "CPU request",
              "required": [],
              "title": "cpu"
            },
            "memory": {
              "default": "256Mi",
              "description": "Memory request",
              "required": [],
              "title": "memory"
            }
          },
          "required": [],
          "title": "requests",
          "type": "object"
        }
      },
      "required": [
        "requests",
        "limits"
      ],
      "title": "resources"
    },
    "service": {
      "additionalProperties": false,
      "description": "Service configuration",
      "properties": {
        "port": {
          "default": "5432",
          "description": "PostgreSQL port",
          "required": [],
          "title": "port"
        }
      },
      "required": [],
      "title": "service"
    },
    "storage": {
      "additionalProperties": false,
      "description": "Persistent storage configuration",
      "properties": {
        "size": {
          "default": "1Gi",
          "description": "Size of the persistent volume",
          "required": [],
          "title": "size"
        },
        "storageClass": {
          "default": "ocs-storagecluster-ceph-rbd",
          "description": "StorageClass for the persistent volume",
          "required": [],
          "title": "storageClass"
        }
      },
      "required": [],
      "title": "storage"
    }
  },
  "required": [],
  "type": "object"
}