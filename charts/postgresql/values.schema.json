{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": true,
      "description": "Pod affinity/anti-affinity rules",
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "Container image configuration",
      "properties": {
        "repository": {
          "default": "registry.redhat.io/rhel9/postgresql-15",
          "description": "Image registry and repository",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "latest",
          "description": "Image tag",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [],
      "title": "image",
      "type": "object"
    },
    "monitor": {
      "default": true,
      "description": "Enable ServiceMonitor for Prometheus",
      "title": "monitor",
      "type": "boolean"
    },
    "postgresql": {
      "additionalProperties": false,
      "description": "PostgreSQL server configuration",
      "properties": {
        "adminPassword": {
          "default": "adminpassword",
          "description": "Admin password (overridden at deploy)",
          "title": "adminPassword",
          "type": "string"
        },
        "database": {
          "default": "sampledb",
          "description": "Database name to create",
          "title": "database",
          "type": "string"
        },
        "password": {
          "default": "password",
          "description": "Custom password (overridden at deploy)",
          "title": "password",
          "type": "string"
        },
        "user": {
          "default": "user",
          "description": "Custom user credentials (overridden at deploy)",
          "title": "user",
          "type": "string"
        }
      },
      "required": [],
      "title": "postgresql",
      "type": "object"
    },
    "resources": {
      "additionalProperties": false,
      "description": "Resource limits and requests",
      "properties": {
        "limits": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "0.5",
              "description": "CPU limit",
              "title": "cpu",
              "type": "string"
            },
            "memory": {
              "default": "512Mi",
              "description": "Memory limit",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [],
          "title": "limits",
          "type": "object"
        },
        "requests": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "0.1",
              "description": "CPU request",
              "title": "cpu",
              "type": "string"
            },
            "memory": {
              "default": "256Mi",
              "description": "Memory request",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [],
          "title": "requests",
          "type": "object"
        }
      },
      "required": [
        "requests",
        "limits"
      ],
      "title": "resources",
      "type": "object"
    },
    "service": {
      "additionalProperties": false,
      "description": "Service configuration",
      "properties": {
        "port": {
          "default": 5432,
          "description": "PostgreSQL port",
          "title": "port",
          "type": "integer"
        }
      },
      "required": [],
      "title": "service",
      "type": "object"
    },
    "storage": {
      "additionalProperties": false,
      "description": "Persistent storage configuration",
      "properties": {
        "size": {
          "default": "1Gi",
          "description": "Size of the persistent volume",
          "title": "size",
          "type": "string"
        },
        "storageClass": {
          "default": "ocs-storagecluster-ceph-rbd",
          "description": "StorageClass for the persistent volume",
          "title": "storageClass",
          "type": "string"
        }
      },
      "required": [],
      "title": "storage",
      "type": "object"
    }
  },
  "required": [],
  "type": "object"
}