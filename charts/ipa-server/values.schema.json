{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": false,
      "description": "Pod affinity/anti-affinity rules",
      "required": [],
      "title": "affinity"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "Container image configuration",
      "properties": {
        "repository": {
          "default": "quay.io/freeipa/freeipa-server",
          "description": "Image registry and repository",
          "required": [],
          "title": "repository"
        },
        "tag": {
          "default": "centos-9-stream",
          "description": "Image tag",
          "required": [],
          "title": "tag"
        }
      },
      "required": [],
      "title": "image"
    },
    "ingress": {
      "additionalProperties": false,
      "description": "Ingress configuration",
      "properties": {
        "className": {
          "default": "openshift-default",
          "description": "Ingress class name (e.g. openshift-default)",
          "required": [],
          "title": "className"
        },
        "enabled": {
          "default": "true",
          "description": "Enable ingress for the IPA server",
          "required": [],
          "title": "enabled"
        },
        "hostname": {
          "default": "ipa-server.example.test",
          "description": "Hostname for the ingress (should match installOpts domain)",
          "required": [],
          "title": "hostname"
        },
        "passthrough": {
          "default": "true",
          "description": "Use TLS passthrough for LDAP/HTTPS",
          "required": [],
          "title": "passthrough"
        }
      },
      "required": [],
      "title": "ingress"
    },
    "ipaServer": {
      "additionalProperties": false,
      "description": "FreeIPA server installation and run options",
      "properties": {
        "adminPassword": {
          "default": "admin2023",
          "description": "Directory Manager / admin password (at least 8 characters)",
          "required": [],
          "title": "adminPassword"
        },
        "command": {
          "default": "ipa-server-install",
          "description": "Command to run in the container",
          "required": [],
          "title": "command"
        },
        "installOpts": {
          "default": "-U -r EXAMPLE.TEST --setup-dns --no-forwarders --no-ntp",
          "description": "setup-dns)",
          "required": [],
          "title": "installOpts"
        }
      },
      "required": [],
      "title": "ipaServer"
    },
    "openshift": {
      "default": "true",
      "description": "Enable OpenShift-specific configuration",
      "required": [],
      "title": "openshift"
    },
    "resources": {
      "additionalProperties": false,
      "description": "Resource limits and requests",
      "properties": {
        "limits": {
          "additionalProperties": false,
          "properties": {
            "memory": {
              "default": "512Mi",
              "description": "Memory limit",
              "required": [],
              "title": "memory"
            }
          },
          "required": [],
          "title": "limits",
          "type": "object"
        }
      },
      "required": [
        "limits"
      ],
      "title": "resources"
    },
    "serviceAccount": {
      "default": "ipa-server",
      "description": "Service account name for the IPA server pods",
      "required": [],
      "title": "serviceAccount"
    },
    "volume": {
      "additionalProperties": false,
      "description": "Persistent volume configuration",
      "properties": {
        "size": {
          "default": "5Gi",
          "description": "Size of the persistent volume (minimum 2Gi for slapd)",
          "required": [],
          "title": "size"
        }
      },
      "required": [],
      "title": "volume"
    }
  },
  "required": [],
  "type": "object"
}