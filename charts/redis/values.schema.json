{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": true,
      "description": "Pod affinity/anti-affinity rules",
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "Container image configuration",
      "properties": {
        "repository": {
          "default": "registry.redhat.io/rhel9/redis-7",
          "description": "Image registry and repository",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "latest",
          "description": "Image tag",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [],
      "title": "image",
      "type": "object"
    },
    "monitor": {
      "default": true,
      "description": "Enable ServiceMonitor for Prometheus",
      "title": "monitor",
      "type": "boolean"
    },
    "redis": {
      "additionalProperties": false,
      "description": "Redis server configuration",
      "properties": {
        "password": {
          "default": "redhat01",
          "description": "Redis password",
          "title": "password",
          "type": "string"
        }
      },
      "required": [],
      "title": "redis",
      "type": "object"
    },
    "resources": {
      "additionalProperties": false,
      "description": "Resource limits and requests",
      "properties": {
        "limits": {
          "additionalProperties": false,
          "properties": {
            "memory": {
              "default": "512Mi",
              "description": "Memory limit",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [],
          "title": "limits",
          "type": "object"
        }
      },
      "required": [
        "limits"
      ],
      "title": "resources",
      "type": "object"
    },
    "service": {
      "additionalProperties": false,
      "description": "Service configuration",
      "properties": {
        "port": {
          "default": 6379,
          "description": "Redis port",
          "title": "port",
          "type": "integer"
        }
      },
      "required": [],
      "title": "service",
      "type": "object"
    }
  },
  "required": [],
  "type": "object"
}